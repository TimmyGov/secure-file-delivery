{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "SecureFileDelivery",
    "Audience": "SecureFileDelivery",
    "SecretKey": ""
  },
  "Storage": {
    "Provider": "Minio",
    "Minio": {
      "Endpoint": "",
      "AccessKey": "",
      "SecretKey": "",
      "BucketName": "statements",
      "UseSSL": false
    },
    "Local": {
      "BasePath": "/app/statements"
    }
  },
  "TokenCleanup": {
    "IntervalMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
