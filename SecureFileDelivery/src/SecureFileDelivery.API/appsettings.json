{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Database=securedelivery;Username=postgres;******"
  },
  "Jwt": {
    "Issuer": "SecureFileDelivery",
    "Audience": "SecureFileDelivery",
    "SecretKey": "change-me-in-production-min-32-chars!!"
  },
  "Storage": {
    "Provider": "Minio",
    "Minio": {
      "Endpoint": "minio:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "BucketName": "statements",
      "UseSSL": false
    },
    "Local": {
      "BasePath": "/app/statements"
    }
  },
  "TokenCleanup": {
    "IntervalMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
